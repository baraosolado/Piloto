# Copie para .env.local e preencha os valores.

# -----------------------------------------------------------------------------
# Docker / Easypanel (produção)
# -----------------------------------------------------------------------------
# Guia: docs/deploy-easypanel.md
# Build args no painel: DATABASE_URL, BETTER_AUTH_URL, BETTER_AUTH_SECRET, NEXT_PUBLIC_APP_URL
# SKIP_DB_MIGRATE=1  — não rodar drizzle-kit migrate na subida do container (se você migra manualmente)
#
# Primeiro super_admin em produção (Docker entrypoint; idempotente — ver docs/deploy-easypanel.md):
# BOOTSTRAP_SUPER_ADMIN=1
# INITIAL_SUPER_ADMIN_EMAIL=admin@seudominio.com.br
# INITIAL_SUPER_ADMIN_PASSWORD=              # mín. 12 caracteres; remover do painel após primeiro login
# INITIAL_SUPER_ADMIN_NAME=Administrador     # opcional
# CRON_BASE_URL=https://seu-dominio.com.br  — para scripts/run-cron-tasks.sh (fallback: NEXT_PUBLIC_APP_URL)
# CRON_SECRET=  — openssl rand -base64 32 (obrigatório para agendar /api/cron/* no Easypanel)

# -----------------------------------------------------------------------------
# Banco de dados (PostgreSQL)
# -----------------------------------------------------------------------------
# URL completa de conexão. Ex.: postgresql://usuario:senha@localhost:5432/copilote_db
DATABASE_URL=

# -----------------------------------------------------------------------------
# Better Auth
# -----------------------------------------------------------------------------
# Segredo para assinatura de sessão/JWT — gere com: openssl rand -base64 32
BETTER_AUTH_SECRET=
# URL base do servidor Better Auth (dev: http://localhost:3000) — sem barra no final
BETTER_AUTH_URL=

# --- Testar no celular (mesma Wi-Fi) ---
# 1) No PC: ipconfig → anote o IPv4 (ex.: 192.168.0.12)
# 2) Suba o app com: npm run dev:lan  (escuta em 0.0.0.0, não só localhost)
# 3) No .env.local, use o IP do PC nas DUAS linhas abaixo (nunca "localhost" no celular):
#    BETTER_AUTH_URL=http://192.168.0.12:3000
#    NEXT_PUBLIC_APP_URL=http://192.168.0.12:3000
# 4) No celular abra exatamente essa URL. Reinicie o npm run após mudar o .env.
# 5) Firewall Windows: permitir Node.js ou porta 3000 (rede privada).
# Opcional: origens extras confiáveis (vírgula), ex.: http://127.0.0.1:3000
# BETTER_AUTH_EXTRA_TRUSTED_ORIGINS=
# Better Auth também lê (vírgula): BETTER_AUTH_TRUSTED_ORIGINS — use se precisar forçar uma origem.

# -----------------------------------------------------------------------------
# App (Next.js) — exposto ao browser
# -----------------------------------------------------------------------------
# Sempre com protocolo (http:// em dev, https:// em prod). Stripe exige URL absoluta nos redirects do Checkout.
# Mesmo host/porta que BETTER_AUTH_URL em dev; usado pelo auth client, links e CORS das API routes
NEXT_PUBLIC_APP_URL=
# E-mail do encarregado (DPO) / privacidade — exibido na página pública /privacidade
NEXT_PUBLIC_DPO_EMAIL=privacidade@seudominio.com.br
# Opcional: se quiser separar, use a URL pública da API de auth (default: NEXT_PUBLIC_APP_URL)
# NEXT_PUBLIC_BETTER_AUTH_URL=

# -----------------------------------------------------------------------------
# Resend (e-mail transacional — recuperação de senha, troca de e-mail, etc.)
# -----------------------------------------------------------------------------
# Criar conta em https://resend.com → API Keys → Create API Key
# RESEND_API_KEY=re_...
# Com a chave definida, o app chama a Resend também em NODE_ENV=development (aparece no painel).
# Sem a chave em dev: recuperação/verificação só logam o link no terminal; troca de e-mail retorna erro.
# Domínio verificado em https://resend.com/domains (ex.: noreply@seudominio.com.br)
# Em dev sem domínio: use onboarding@resend.dev — o destinatário (campo "to") precisa ser
# o MESMO e-mail da sua conta Resend; para outros endereços a API retorna 403 até verificar domínio.
# RESEND_FROM_EMAIL=noreply@seudominio.com.br
# Alternativa legada (só o endereço, mesmo efeito que RESEND_FROM_EMAIL):
# RESEND_FROM=

# -----------------------------------------------------------------------------
# Contas de desenvolvedor (acesso total: Premium + sem limites de corridas/gastos)
# -----------------------------------------------------------------------------
# UUID do usuário (vários: separados por vírgula, sem espaços ou com espaços — são trimados)
# PILOTO_DEVELOPER_USER_IDS=
# E-mails só de engenharia (vários: separados por vírgula). Não use e-mails de teste de motoristas aqui —
# essas contas passam a ser tratadas como "dev" (sem fluxo real de assinatura na página de plano).
# PILOTO_DEVELOPER_EMAILS=dev@seudominio.com.br

# -----------------------------------------------------------------------------
# Stripe (pagamentos — Checkout, Customer Portal, webhooks)
# Dashboard: https://dashboard.stripe.com (use "Test mode" em desenvolvimento)
# -----------------------------------------------------------------------------
# Chave secreta da API — Developers → API keys → "Secret key" (reveal)
# Teste: sk_test_... | Produção: sk_live_...
STRIPE_SECRET_KEY=
# Segredo para validar webhooks — Developers → Webhooks → seu endpoint → "Signing secret"
# Cada endpoint tem um whsec_... próprio. Em local: `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
# e use o whsec que o CLI imprime, ou crie um endpoint de teste no dashboard apontando para URL pública (ex.: ngrok).
STRIPE_WEBHOOK_SECRET=
# Chave publicável (browser / Stripe.js / Payment Element) — Developers → API keys → "Publishable key"
# pk_test_... ou pk_live_... (hoje o app usa Checkout hospedado; reserve para futuras integrações no front)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Preços Premium: Product catalog → Prices. Use sempre IDs price_... de preço **Recurring** (assinatura).
# Preço "One time" ou prod_... quebra o Checkout (modo subscription).
# Alinhe valores com src/lib/pricing.ts (UI).
# Mensal: recurring "monthly" (~R$ 12,90) — obrigatório para checkout.
STRIPE_PREMIUM_PRICE_ID_MONTHLY=
# Legado: se só esta variável existir, o app usa como mensal (também deve ser recurring).
# STRIPE_PREMIUM_PRICE_ID=
# Anual: recurring "yearly" — opcional; sem isso só aparece o plano mensal.
# STRIPE_PREMIUM_PRICE_ID_YEARLY=

# -----------------------------------------------------------------------------
# Web Push — alertas de manutenção (navegador / sistema)
# -----------------------------------------------------------------------------
# Gere o par: npm run push:vapid   (ou: npx web-push generate-vapid-keys)
# Use os nomes exatos abaixo, sem espaço em volta do "=". Depois de salvar,
# reinicie o servidor (npm run dev).
#
# VAPID_SUBJECT=mailto:seu@email.com
# VAPID_PUBLIC_KEY=colar_chave_publica_aqui
# VAPID_PRIVATE_KEY=colar_chave_privada_aqui
#
# Opcional: a chave pública também pode ser NEXT_PUBLIC_VAPID_PUBLIC_KEY=...
# (o app aceita qualquer um dos dois nomes para a pública).
#
# Cron que dispara o envio (ex.: Vercel Cron ou curl com agendador):
# CRON_SECRET=  # openssl rand -base64 32
# GET /api/cron/maintenance-push
#   Header: Authorization: Bearer <CRON_SECRET>
#   ou: x-cron-secret: <CRON_SECRET>
# Em dev você pode chamar manualmente após ativar notificações e ter itens em alerta.
#
# Retenção LGPD — anonimização de contas muito antigas (SECURITY-GAPS §5.11):
# GET ou POST /api/cron/data-retention (mesmos headers de secret)
# Por defeito NÃO altera dados — ative explicitamente em produção:
# DATA_RETENTION_CRON_ENABLED=1
# Opcional: DATA_RETENTION_ANONYMIZE_AFTER_YEARS=3  (default 3)
# Opcional: DATA_RETENTION_MAX_PER_RUN=25
# Opcional: DATA_RETENTION_DRY_RUN=1  (só contagem, sem UPDATE)
#
# Logs de segurança — reenvio opcional para agregador HTTP (JSON por linha no body):
# SECURITY_LOG_INGEST_URL=https://...
# SECURITY_LOG_INGEST_TOKEN=  # Bearer opcional

# -----------------------------------------------------------------------------
# Sentry (erros e performance em produção)
# Projeto: org piloto / javascript-nextjs (sentry.io)
# -----------------------------------------------------------------------------
# DSN: Settings → Client Keys (DSN) do projeto javascript-nextjs
# NEXT_PUBLIC_SENTRY_DSN=
# Opcional no servidor: se diferente do público
# SENTRY_DSN=
# Org e projeto (default no next.config: piloto / javascript-nextjs)
# SENTRY_ORG=piloto
# SENTRY_PROJECT=javascript-nextjs
# Token com escopo project:releases (upload de source maps no `next build`)
# SENTRY_AUTH_TOKEN=
# Ambiente exibido no Sentry (default: NODE_ENV ou VERCEL_ENV)
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=
# SENTRY_ENVIRONMENT=
