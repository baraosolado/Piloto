## Banco de dados

### Conexão (src/lib/db.ts)
import { drizzle } from "drizzle-orm/node-postgres"
import { Pool } from "pg"
import * as schema from "@/db/schema"
const pool = new Pool({ connectionString: process.env.DATABASE_URL })
export const db = drizzle(pool, { schema })

### Enums do schema
platformEnum: uber | 99 | indrive | particular
expenseCategoryEnum: fuel | maintenance | insurance | fine | other

### Tabelas
users: id, name, email (único), passwordHash, city, createdAt, updatedAt
sessions: gerenciada pelo Better Auth
vehicles: id, userId (fk cascade), model, year, fuelConsumption, fuelPrice, depreciationPerKm (default 0.10), currentOdometer
platformsUsed: id, userId (fk cascade), platform
rides: id, userId (fk cascade), platform, grossAmount, distanceKm, startedAt, durationMinutes?, notes?, createdAt
expenses: id, userId (fk cascade), category, amount, odometer?, liters?, description?, occurredAt, createdAt
goals: id, userId (fk cascade), monthlyTarget, month, year, achieved (default false)
maintenanceItems: id, userId (fk cascade), type, lastServiceKm, lastServiceAt, intervalKm, estimatedCost?
subscriptions: id, userId (fk cascade único), plan (default 'free'), stripeCustomerId?, stripeSubscriptionId?, currentPeriodEnd?, cancelAtPeriodEnd (default false), createdAt

### Comandos Drizzle
npx drizzle-kit generate   → gera migration após mudar schema
npx drizzle-kit migrate    → aplica no banco
npx drizzle-kit studio     → GUI visual (desenvolvimento)

