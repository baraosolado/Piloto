{
  "name": "copilote-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack -p 3000",
    "dev:lan": "next dev --turbopack -p 3000 -H 0.0.0.0",
    "build": "next build",
    "start": "next start -H 0.0.0.0",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:verify": "node scripts/verify-db-schema.mjs",
    "db:reset": "node scripts/reset-db-dev.mjs",
    "db:studio": "drizzle-kit studio",
    "db:test": "node scripts/test-db.mjs",
    "db:seed:dev-users": "node scripts/seed-dev-users.mjs",
    "db:bootstrap:super-admin": "node scripts/bootstrap-super-admin.mjs",
    "db:update-dev-email": "node scripts/update-dev-user-email.mjs",
    "sentry:wizard": "npx @sentry/wizard@latest -i nextjs --saas --org piloto --project javascript-nextjs",
    "deploy": "bash scripts/deploy.sh",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
    "pm2:reload": "pm2 reload copilote --update-env",
    "pm2:stop": "pm2 stop copilote",
    "pm2:logs": "pm2 logs copilote",
    "pm2:status": "pm2 status",
    "db:backup": "bash scripts/backup-db.sh",
    "push:vapid": "node -e \"const w=require('web-push');const v=w.generateVAPIDKeys();console.log('VAPID_PUBLIC_KEY='+v.publicKey);console.log('VAPID_PRIVATE_KEY='+v.privateKey);\""
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@react-pdf/renderer": "^4.3.0",
    "@sentry/nextjs": "^10.45.0",
    "better-auth": "1.2.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.30.0",
    "drizzle-orm": "^0.41.0",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.23.26",
    "import-in-the-middle": "3.0.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.487.0",
    "next": "15.2.4",
    "pg": "^8.13.3",
    "radix-ui": "^1.4.3",
    "rate-limiter-flexible": "^5.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.55.0",
    "recharts": "^2.15.1",
    "resend": "^4.0.0",
    "sonner": "^2.0.3",
    "stripe": "^17.7.0",
    "tailwind-merge": "^3.2.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "web-push": "^3.6.7",
    "zod": "^3.24.2"
  },
  "overrides": {
    "import-in-the-middle": "3.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "eslint": "^9",
    "eslint-config-next": "15.2.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
